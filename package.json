{
  "name": "infospot-frontend",
  "version": "1.0.0",
  "description": "Frontend build tools for InfoSpot platform",
  "scripts": {
    "build-css": "tailwindcss -i ./static/css/tailwind.css -o ./static/css/tailwind.min.css --minify",
    "watch-css": "tailwindcss -i ./static/css/tailwind.css -o ./static/css/tailwind.min.css --watch",
    "dev": "npm run watch-css"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "tailwindcss": "^3.4.0"
  },
  "dependencies": {
    "alpinejs": "^3.13.0",
    "chart.js": "^4.4.0"
  }
}